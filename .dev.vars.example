# =============================================================================
# Cloudflare Pages Functions secrets — local dev preview
# =============================================================================
# Copy this file to `.dev.vars` (which is in .gitignore) and fill in the real
# values. `wrangler pages dev` and the local CF Pages dev runtime read from
# `.dev.vars` automatically. Do NOT commit `.dev.vars`.
#
# In production, set these in Cloudflare Pages dashboard:
#   Project → Settings → Environment variables → Production
# Mark secrets (STRIPE_SECRET_KEY, STRIPE_WEBHOOK_SECRET,
# SUPABASE_SERVICE_ROLE_KEY, RESEND_API_KEY, JWT_SECRET) as type "Secret"
# so they don't leak in build logs.
# =============================================================================

# --- Stripe (E10) -----------------------------------------------------------
# Test mode keys during development; live keys after Stripe verifies the s.r.o.
# Get from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_PUBLISHABLE_KEY=pk_test_replace_me

# Webhook signing secret. Easiest: run `npm run dev:stripe` — the launcher
# fetches the current secret via `stripe listen --print-secret` and writes
# it here for you. Manual fallback:
#   stripe listen --forward-to http://localhost:8788/api/stripe-webhook
# Or in Dashboard → Developers → Webhooks → endpoint → "Signing secret".
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Reject events whose Stripe `livemode` flag doesn't match this value.
# "false" = accept only test-mode events (correct for local dev).
# "true"  = accept only live-mode events (set in production CF Pages env).
# Unset   = accept either (legacy permissive default).
EXPECTED_LIVEMODE=false

# --- Supabase (E10.3 webhook needs service role) ----------------------------
# Service role key bypasses RLS — NEVER ship to the client bundle.
# Get from Supabase Dashboard → Project Settings → API → service_role key.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ_replace_me

# --- Cloudflare Turnstile (E11.4 portal magic link verification) ------------
# Server-side secret used to validate the token the browser submits with the
# magic-link form. Public site key lives in .env (VITE_TURNSTILE_SITE_KEY).
# Get from https://dash.cloudflare.com → Turnstile → site → "Secret Key".
# Use the test secret "1x0000000000000000000000000000000AA" for local dev.
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# Per-email cooldown + global daily cap on portal magic-link sends.
# Defaults are sane; override only when scaling up.
PORTAL_LINK_DAILY_CAP=200
PORTAL_LINK_COOLDOWN_SECONDS=900
PORTAL_LINK_PER_IP_PER_HOUR=10

# --- Email (E11.8) ----------------------------------------------------------
# Resend API key for transactional emails (magic link, refund alerts).
# Get from https://resend.com/api-keys.
RESEND_API_KEY=re_replace_me
EMAIL_FROM=noreply@subenai.sk
EMAIL_REPLY_TO=subenai.podpora@gmail.com
OPS_EMAIL=subenai.podpora@gmail.com

# --- JWT (E12 author auth + E12.3 respondent attempt token) -----------------
# Random 32-byte hex string. Generate via:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_me_with_64_hex_chars

# --- Site (informational; used in absolute URLs from server functions) ------
SITE_ORIGIN=https://subenai.sk
