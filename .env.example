# Copy this file to `.env` and fill in your own Supabase project values.
# Get these from: Supabase dashboard → Settings → API
#
# All variables prefixed with VITE_ are exposed to the browser bundle.
# The Supabase `anon` (publishable) key is designed to be public — Row Level
# Security policies on the database enforce access control. NEVER put the
# `service_role` key here.

# Your Supabase project URL, e.g. https://abcdefgh.supabase.co
VITE_SUPABASE_URL=

# Your Supabase anon (publishable) key — the long JWT starting with eyJ...
VITE_SUPABASE_PUBLISHABLE_KEY=

# Project ref — the part of the URL before .supabase.co
VITE_SUPABASE_PROJECT_ID=

# --- Cloudflare Turnstile (E11.4 portal magic link bot challenge) ---------
# Public site key — safe to ship in the client bundle.
# Get from https://dash.cloudflare.com → Turnstile → Add site → copy "Site Key".
# Use the test key "1x00000000000000000000AA" for local dev (always passes).
VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA
