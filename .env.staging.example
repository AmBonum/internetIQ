# Staging Supabase project credentials for AH-1 migration verification.
#
# How to fill in:
# 1. Open the staging project in Supabase Dashboard (separate from prod).
# 2. Go to Project Settings -> Database -> Connection string.
# 3. Pick the "URI" tab (not "Pooler" — we want direct DB access for
#    DDL + RLS introspection).
# 4. Copy the URI and paste below; replace [YOUR-PASSWORD] with the
#    database password from Project Settings -> Database -> Connection info.
#
# Then run:
#   cp .env.staging.example .env.staging  # never commit .env.staging
#   bash scripts/verify-supabase-migration.sh
#
# This file is in .gitignore. Never commit the real .env.staging with the
# password.

DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[STAGING-REF].supabase.co:5432/postgres"
